<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="32,24,32,32" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Hero -->
            <Border Grid.Row="0" CornerRadius="16" Padding="28,22"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Welcome back" FontSize="12" Opacity="0.45" Foreground="White" FontWeight="Medium"/>
                        <TextBlock Text="Ease of Access" FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Your accessibility control centre — pick a feature below to get started."
                                   FontSize="13" Opacity="0.6" Foreground="White"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="12" Padding="24,14"
                            VerticalAlignment="Center" Margin="24,0,0,0"
                            Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="ActiveCountText" Text="0" FontSize="32" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="features on" FontSize="11" Opacity="0.5"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Row 1: Key Reprogramming · Tiling Manager · Mouseless -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="16">

                <!-- Key Reprogramming -->
                <Border Grid.Column="0" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#3B82F6" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="⌨" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="ReprogramBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="ReprogramBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Key Reprogramming" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Remap any key to another key or mouse button system-wide."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="ReprogramKeys_Click"/>
                    </Grid>
                </Border>

                <!-- Tiling Manager -->
                <Border Grid.Column="1" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#8B5CF6" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="▦" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="TilingBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="TilingBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Tiling Manager" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Snap and organise windows into tiled layouts automatically."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="TilingManager_Click"/>
                    </Grid>
                </Border>

                <!-- Mouseless -->
                <Border Grid.Column="2" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#F97316" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="🖱" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="MouselessBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="MouselessBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Mouseless" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Control your mouse cursor entirely from the keyboard."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="Mouseless_Click"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- Row 2: Commands · Eyesight · Assistant -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="16">

                <!-- Commands -->
                <Border Grid.Column="0" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#EAB308" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="⚡" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="CommandsBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="CommandsBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Commands" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Bind hotkeys to launch apps, scripts and custom actions fast."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="Commands_Click"/>
                    </Grid>
                </Border>

                <!-- Eyesight -->
                <Border Grid.Column="1" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#06B6D4" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="👁" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="EyesightBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="EyesightBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Eyesight" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Visual aids and screen enhancements for easier reading."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="Eyesight_Click"/>
                    </Grid>
                </Border>

                <!-- Assistant -->
                <Border Grid.Column="2" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="#22C55E" BorderThickness="0,3,0,0"
                        PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <TextBlock Text="🤖" FontSize="30" VerticalAlignment="Center"/>
                            <Border x:Name="AssistantBadge" Grid.Column="1" CornerRadius="20" Padding="10,4"
                                    Background="#50647484" VerticalAlignment="Center">
                                <TextBlock x:Name="AssistantBadgeText" Text="Off" FontSize="11"
                                           FontWeight="Medium" Foreground="White"/>
                            </Border>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock Text="Assistant" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="AI-powered assistant to help you navigate and use the app."
                                       FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Row="2" Content="Open →" HorizontalAlignment="Stretch"
                                Click="Assistant_Click"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- Tip card -->
            <Border Grid.Row="3" CornerRadius="12" Padding="20,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="💡" FontSize="20"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Text="Getting started" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Enable a feature using its toggle, then configure it from its panel. Features run silently in the background once switched on."
                                   FontSize="12" Opacity="0.55" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
