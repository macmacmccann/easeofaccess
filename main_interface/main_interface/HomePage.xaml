<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid Padding="24">
            <!-- 2 rows and 3 columns -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                Background="Transparent" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <TextBlock Text="Home" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
       Background="Transparent" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <TextBlock Text="Control Panel To help you with the important stuff" 
              FontSize="20" 
              FontWeight="Bold" 
              Foreground="White" 
              HorizontalAlignment="Center"
              VerticalAlignment="Center"/>
            </Border>



            <!-- Box 1 -->
            <Border Grid.Row="2" Grid.Column="0" Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,12,8"
        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="8">
                        <!-- Title -->
                        <TextBlock Text="For Developers" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Foreground="White" 
                       TextAlignment="Center"/>

                        <!-- Description -->
                        <TextBlock Text="See how tools on this app can overflow to help you while you are working." 
                       FontSize="12" 
                       Opacity="0.9" 
                       Foreground="White" 
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>

                        <!-- Navigation Links -->
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Button Content="Code Fast" 
                        HorizontalAlignment="Stretch" 
                        Click="Commands_Click"/>
                            <Button Content="" 
                        HorizontalAlignment="Stretch" 
                        Click="LoginPage2_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Box 2 -->
            <Border Grid.Row="2" Grid.Column="1" Background="Transparent" CornerRadius="8" Padding="16" Margin="12,8,12,8"
                PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Button Content="Toggle" HorizontalAlignment="Stretch" Click="Box2_Click"/>
                        <TextBlock Text="Description for Box 2" FontSize="12" Opacity="0.9" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Box 3 -->
            <Border Grid.Row="2" Grid.Column="2" Background="Transparent" CornerRadius="8" Padding="16" Margin="12,8,0,8"
                PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Button Content="Box 3" HorizontalAlignment="Stretch" Click="Box3_Click"/>
                        <TextBlock Text="Description for Box 3" FontSize="12" Opacity="0.9" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Box 4 -->
            <Border Grid.Row="3" Grid.Column="0" Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,12,8"
                PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Button Content="Box 4" HorizontalAlignment="Stretch" Click="Box4_Click"/>
                        <TextBlock Text="Description for Box 4" FontSize="12" Opacity="0.9" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Box 5 -->
            <Border Grid.Row="3" Grid.Column="1" Background="Transparent" CornerRadius="8" Padding="16" Margin="12,8,12,8"
                PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Button Content="Box 5" HorizontalAlignment="Stretch" Click="Box5_Click"/>
                        <TextBlock Text="Description for Box 5" FontSize="12" Opacity="0.9" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Box 6 -->
            <Border Grid.Row="3" Grid.Column="2" Background="Transparent" CornerRadius="8" Padding="16" Margin="12,8,0,8"
                PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <Button Content="Box 6" HorizontalAlignment="Stretch" Click="Box6_Click"/>
                        <TextBlock Text="Description for Box 6" FontSize="12" Opacity="0.9" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </ScrollViewer>
</Page>
