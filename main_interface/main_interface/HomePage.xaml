<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="32,24,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,32">
                <TextBlock Text="Ease of Access" FontSize="36" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Your accessibility control centre" FontSize="14" Opacity="0.6" Foreground="White"/>
            </StackPanel>

            <!-- Row 1 -->
            <Grid Grid.Row="1" Margin="0,0,0,16"
                  ColumnDefinitions="*,*,*" ColumnSpacing="16">

                <!-- Key Reprogramming -->
                <Border Grid.Column="0" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="⌨" FontSize="28"/>
                        <TextBlock Text="Key Reprogramming" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Remap any key to another key or mouse button system-wide."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="ReprogramKeys_Click"/>
                    </StackPanel>
                </Border>

                <!-- Tiling Manager -->
                <Border Grid.Column="1" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="▦" FontSize="28"/>
                        <TextBlock Text="Tiling Manager" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Snap and organise windows into tiled layouts automatically."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="TilingManager_Click"/>
                    </StackPanel>
                </Border>

                <!-- Mouseless -->
                <Border Grid.Column="2" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="🖱" FontSize="28"/>
                        <TextBlock Text="Mouseless" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Control your mouse cursor entirely from the keyboard."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="Mouseless_Click"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Row 2 -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*,*" ColumnSpacing="16">

                <!-- Commands -->
                <Border Grid.Column="0" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="⚡" FontSize="28"/>
                        <TextBlock Text="Commands" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Bind hotkeys to launch apps, scripts and custom actions fast."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="Commands_Click"/>
                    </StackPanel>
                </Border>

                <!-- Eyesight -->
                <Border Grid.Column="1" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="👁" FontSize="28"/>
                        <TextBlock Text="Eyesight" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Visual aids and screen enhancements for easier reading."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="Eyesight_Click"/>
                    </StackPanel>
                </Border>

                <!-- Assistant -->
                <Border Grid.Column="2" Background="Transparent" CornerRadius="12" Padding="20"
                        PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                    <StackPanel Spacing="10">
                        <TextBlock Text="🤖" FontSize="28"/>
                        <TextBlock Text="Assistant" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="AI-powered assistant to help you navigate and use the app."
                                   FontSize="12" Opacity="0.6" Foreground="White" TextWrapping="Wrap"/>
                        <Button Content="Open" HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Click="Assistant_Click"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
