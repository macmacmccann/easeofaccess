<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.TerminalControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid RowDefinitions="0.2*,*">

            <!-- HEADER -->
            <Border x:Name="Headertop" Background="#FF1E1E1E">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Top" Height="120" Padding="16" Margin="24,24,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Terminal Assistant" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock Text="Run commands without leaving the app" FontSize="14" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- END HEADER -->

            <!-- BODY -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16" Margin="24,24,0,0">

                <!-- LEFT: description + info cards -->
                <StackPanel Grid.Column="0" Spacing="16" Margin="0,0,16,0">

                    <TextBlock Text="What this does" FontSize="20" Opacity="0.7" />

                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16">
                        <TextBlock
                            Text="The Terminal gives you direct access to your system's command line from inside the app — run scripts, launch programs, or issue one-off commands without switching context or opening a separate window."
                            FontSize="13"
                            Opacity="0.85"
                            TextWrapping="Wrap" />
                    </Border>

                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Good to know" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="⌨  Commands run in your default shell (cmd / PowerShell)"  FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="📋  Output is shown inline below each command"             FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="🔁  History is kept for the session"                       FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="⚠   Admin commands may require elevated permissions"       FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- RIGHT: coming soon placeholder -->
                <StackPanel Grid.Column="1" Spacing="8">

                    <TextBlock Text="Terminal" FontSize="20" Opacity="0.7" />

                    <Border Background="#FF1A1A1A" CornerRadius="12" Padding="24" MinHeight="320"
                            BorderBrush="#FF3A3A3A" BorderThickness="1">
                        <StackPanel Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&gt;_" FontSize="48" FontWeight="Bold" Opacity="0.3"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                            <TextBlock Text="Terminal embed coming soon"
                                       FontSize="14" Opacity="0.4"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Use the Terminal Assistant page in the sidebar for now"
                                       FontSize="12" Opacity="0.3"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>
