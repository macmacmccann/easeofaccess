<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.AssistantControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid RowDefinitions="0.2*,*">

            <!-- HEADER -->
            <Border x:Name="Headertop">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Top" Height="120" Padding="16" Margin="24,24,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Let the App Think For You" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock Text="Set rules and let your accessibility features activate automatically" FontSize="14" Opacity="0.7" />
                    </StackPanel>

                    <ToggleSwitch
                        x:Name="AutomationMasterToggle"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="AutomationMasterToggled"
                        FontSize="16" MinHeight="48" Padding="4" VerticalAlignment="Center">
                        <ToggleSwitch.RenderTransform>
                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                        </ToggleSwitch.RenderTransform>
                    </ToggleSwitch>
                </StackPanel>
            </Border>
            <!-- END HEADER -->

            <!-- BODY -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16" Margin="24,24,0,0">

                <!-- LEFT: status panel -->
                <StackPanel Grid.Column="0" Spacing="16">

                    <TextBlock Text="What this does" FontSize="20" Opacity="0.7" />

                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                        <TextBlock
                            Text="Instead of remembering to turn features on yourself, set a rule once and the app does it for you — activate Dim Screen at a set time, enable Tiling Manager when you have too many windows open, and more."
                            FontSize="13"
                            Opacity="0.85"
                            TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Automation status" FontSize="20" Opacity="0.7" />

                    <!-- Live status readout -->
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Currently" FontSize="13" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock
                                x:Name="StatusLabel"
                                Text="Off"
                                FontSize="48"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock
                                x:Name="ActiveAutomationsLabel"
                                Text="Enable automation to get started"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Opacity="0.5"/>
                        </StackPanel>
                    </Border>

                    <!-- How it works -->
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="How automations work" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="⏰  Time rules fire once per day at the set time"    FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="🪟  Window count rules watch your open windows"      FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="🔔  The master toggle pauses all automations"        FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="🔁  Rules reset at midnight ready for the next day"  FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- RIGHT: automation rule cards -->
                <StackPanel Grid.Column="1" Spacing="8">

                    <TextBlock Text="Automation rules" FontSize="20" Opacity="0.7" />

                    <!-- ── Dim Screen (FUNCTIONAL) ── -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <StackPanel Spacing="12">

                            <!-- Name + toggle row -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="🌙  Dim Screen" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Turn on the night overlay after a set time" FontSize="12" Opacity="0.9" Foreground="White"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="DimScreenAutoToggle"
                                             OffContent="Off" OnContent="On"
                                             VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>

                            <!-- Time picker row -->
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Turn on at" FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TimePicker Grid.Column="1" x:Name="DimScreenTimePicker"
                                            ClockIdentifier="24HourClock"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Tiling Manager ── -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <StackPanel Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="⊞  Tiling Manager" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Enable after N windows are open" FontSize="12" Opacity="0.9" Foreground="White"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="TilingAutoToggle"
                                             OffContent="Off" OnContent="On"
                                             Toggled="TilingAutoToggled"
                                             VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Windows open" FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <NumberBox Grid.Column="1" x:Name="TilingWindowCountBox"
                                           Value="4" Minimum="2" Maximum="20"
                                           SpinButtonPlacementMode="Inline"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Dyslexia Support ── -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <StackPanel Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="📖  Dyslexia Support" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Activate reading overlay on a schedule" FontSize="12" Opacity="0.9" Foreground="White"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="DyslexiaAutoToggle"
                                             OffContent="Off" OnContent="On"
                                             Toggled="DyslexiaAutoToggled"
                                             VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Turn on at" FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TimePicker Grid.Column="1" x:Name="DyslexiaTimePicker"
                                            ClockIdentifier="24HourClock"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Mouseless Mode ── -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <StackPanel Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="🖱  Mouseless Mode" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Switch to keyboard-only mode at a set time" FontSize="12" Opacity="0.9" Foreground="White"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="MouselessAutoToggle"
                                             OffContent="Off" OnContent="On"
                                             Toggled="MouselessAutoToggled"
                                             VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="Turn on at" FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TimePicker Grid.Column="1" x:Name="MouselessTimePicker"
                                            ClockIdentifier="24HourClock"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>
