<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.EyesightControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"



    xmlns:controls="using:main_interface.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid RowDefinitions="0.2*,*,Auto,Auto">

        <!-- HEADER -->
        <Border x:Name="Headertop">


            <Grid Height="120" Padding="16" Margin="24,24,0,0" ColumnDefinitions="Auto,Auto,*" VerticalAlignment="Top">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Enable Monitor Control" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock Text="Use your monitor to build a better relationship with your eyes and your brain"
                                   FontSize="14" Opacity="0.7" />
                    </StackPanel>
                    <ToggleSwitch
                        x:Name="MonitorColorFixEnabledToggle"
                        OffContent="Off" OnContent="On"
                        Toggled="MonitorColorFixEnabledToggled"
                        FontSize="16" MinHeight="48" Padding="4"
                        VerticalAlignment="Center"
                        PointerEntered="Border_PointerEntered"
                        PointerExited="Border_PointerExited">
                        <ToggleSwitch.RenderTransform>
                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                        </ToggleSwitch.RenderTransform>
                    </ToggleSwitch>
                </StackPanel>
                <Border Grid.Column="1" Background="#20FFFFFF" CornerRadius="10"
                        Padding="14,10" VerticalAlignment="Center" Margin="24,0,0,0">
                    <controls:HotKeyCaptureControl x:Name="EyesightShortcut" Label="Toggle hotkey" HotkeyId="2001"/>
                </Border>
            </Grid>

        </Border>
        <!-- END OF HEADER -->

        <!-- COL 1: GIF  GRID ROW 1 OF MAIN GRID -->

        <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16" Margin="24,24,0,0">

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock
                    Text="What this does"
                    FontSize="20"
                    Opacity="0.7"
                    VerticalAlignment="Top" />

                <Border Background="#20FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                    <TextBlock
                        Text="Your screen emits high-energy light that strains your eyes, disrupts sleep, and can trigger headaches — these overlays shift your display's colour temperature to reduce that impact, with presets for specific conditions like migraine sensitivity or dyslexia."
                        FontSize="13"
                        Opacity="0.85"
                        TextWrapping="Wrap" />
                </Border>

                <!-- gif -->

                <Image Source="/Assets/gifs/Monitor.jpg" />

                <!-- -->



            </StackPanel>

            <!-- COL 2: FEATURES -->

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock
                    Grid.Column="1"
                    Text="Features"
                    FontSize="20"
                    Opacity="0.7"
                    VerticalAlignment="Top" />

                <!-- toggles -->


                    <!-- NICE TOGGLE BAR BORDER WRAPPED -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
            PointerExited="Border_PointerExited">
                        <!-- GRID COL 1  WITH TWO DESC UNDER EACHOTHER -->
                        <Grid ColumnDefinitions="*,Auto">

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="High Intensity" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="Proven set intensity for effective support" FontSize="12" Opacity="0.9" Foreground="White" />
                            </StackPanel>

                            <!-- GRID COL 2 TOGGLE -->
                            <ToggleSwitch 
                                Grid.Column="1"
                                 x:Name="HighStrengthToggle"
                               Header="Apply"
                               OffContent="Disabled"
                               OnContent="Enabled"
                               Toggled="HighStrengthToggle_Toggled" 
                                VerticalAlignment="Center"
                                Margin="16,0,0,0" />
                        </Grid>
                    </Border>



                    <!-- NICE TOGGLE BAR BORDER WRAPPED -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
   PointerExited="Border_PointerExited">
                        <!-- GRID COL 1  WITH TWO DESC UNDER EACHOTHER -->
                        <Grid ColumnDefinitions="*,Auto">

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="Medium Intensity" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="Meet in the middle" FontSize="12" Opacity="0.9" Foreground="White" />
                            </StackPanel>

                            <!-- GRID COL 2 TOGGLE -->
                            <ToggleSwitch 
                               Grid.Column="1"
                                x:Name="MediumStrengthToggle"
                              Header="Medium Speed"
                              OffContent="Disabled"
                              OnContent="Enabled"
                              Toggled="MediumStrengthToggle_Toggled" 
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                        </Grid>
                    </Border>



                    <!-- NICE TOGGLE BAR BORDER WRAPPED -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
   PointerExited="Border_PointerExited">
                        <!-- GRID COL 1  WITH TWO DESC UNDER EACHOTHER -->
                        <Grid ColumnDefinitions="*,Auto">

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="Low Intensity" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="Introduce a light colour shift" FontSize="12" Opacity="0.9" Foreground="White" />
                            </StackPanel>

                            <!-- GRID COL 2 TOGGLE -->
                            <ToggleSwitch 
                               Grid.Column="1"
                                x:Name="LowStrengthToggle"
                              Header="Slow Speed"
                              OffContent="Disabled"
                              OnContent="Enabled"
                              Toggled="LowStrengthToggle_Toggled" 
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                        </Grid>
                    </Border>




                </StackPanel>

        </Grid>


         


            <!-- MIDDLE PAGE BARRIER  -->

            <!-- HEADER row 2 of main grid -->
            <Grid Grid.Row="2" Background="#80FAD89C" HorizontalAlignment="Stretch" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>



                <Border x:Name="SplitPage"
            Grid.Column="0"
                Margin="30"
                 HorizontalAlignment="Stretch"
                VerticalAlignment="Center">

                    <TextBlock
                    
                   Text="YOU DECIDE HOW YOUR COMPUTER BEHAVES"
                    FontSize="22"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
                </Border>


                <Button Grid.Column ="1"  x:Name="TipIcon1" Content="Remind Me" Margin="0,0,70,0"/>
                <muxc:TeachingTip x:Name="TipContent1" Target="{x:Bind TipIcon1}"/>

            </Grid>
   <!--  BOTTOM OF PAGE -->

            <!-- BOTTOM TOGGLES ROW 3 of msin grid  -->

            <Grid Grid.Row="3" RowDefinitions="*,*,*"
                  ColumnDefinitions="*,*,*"
                  HorizontalAlignment="Stretch"
                  Margin="40,0,0,0">


                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
                    PointerExited="Border_PointerExited">

                    <Grid ColumnDefinitions="*,*">

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Dim Screen" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Late Night Work" FontSize="12" Opacity="0.9" Foreground="White" />
                        </StackPanel>
                        <ToggleSwitch
                    Grid.Column="1"
                    x:Name="DimScreenEnabledToggle"
                    Header="Apply"
                    OffContent="Disabled"
                    OnContent="Enabled"
                    Toggled="DimScreenEnabledToggled" />
                    </Grid>
                </Border>


                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
                    PointerExited="Border_PointerExited">

                    <Grid ColumnDefinitions="*,*">

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="4">
                            <TextBlock Text="Dyslexia Support" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Prevent exitability" FontSize="12" Opacity="0.9" Foreground="White" />
                        </StackPanel>
                        <ToggleSwitch
                        Grid.Column="1"
                        x:Name="DyslexiaEnabledToggle"
                        Header="Apply"
                        OffContent="Disabled"
                        OnContent="Enabled"
                        Toggled="DyslexiaEnabledToggled" />
                    </Grid>
                </Border>


                <Border
                   Grid.Row="0"
                   Grid.Column="2"
                   Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
                   PointerExited="Border_PointerExited">

                    <Grid ColumnDefinitions="*,*">

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="4">
                            <TextBlock Text="Photophobia / Insomnia " FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Disable High Wavelength" FontSize="12" Opacity="0.9" Foreground="White" />
                        </StackPanel>
                        <ToggleSwitch
                       Grid.Column="1"
                       x:Name="LightSensitiveEnabledToggle"
                       Header="Apply"
                       OffContent="Disabled"
                       OnContent="Enabled"
                       Toggled="LightSensitiveEnabledToggled" />
                    </Grid>
                </Border>

                <Border
                   Grid.Row="1"
                   Grid.Column="0"
                   Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
                   PointerExited="Border_PointerExited">

                    <Grid ColumnDefinitions="*,*">

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="4">
                            <TextBlock Text="Migraine Control" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Help relax your brain" FontSize="12" Opacity="0.9" Foreground="White" />
                        </StackPanel>
                        <ToggleSwitch
                      Grid.Column="1"
                      x:Name="MigraineEnabledToggle"
                      Header="Apply"
                      OffContent="Disabled"
                      OnContent="Enabled"
                      Toggled="MigraineEnabledToggled" />

                    </Grid>
                </Border>

                <Border
                   Grid.Row="1"
                   Grid.Column="1"
                   Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8" PointerEntered="Border_PointerEntered"
                   PointerExited="Border_PointerExited">

                    <Grid ColumnDefinitions="*,*">

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="4">
                            <TextBlock Text="Anxiety Relief" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Relax your nervous system " FontSize="12" Opacity="0.9" Foreground="White" />
                        </StackPanel>
                        <ToggleSwitch                 
                                Grid.Row="1"
                                Grid.Column="1"
                              x:Name="FireEnabledToggle"
                              Header="Apply"
                              OffContent="Disabled"
                              OnContent="Enabled"
                              Toggled="FireEnabledToggled" />
                    </Grid>
                </Border>



            </Grid>







    </Grid>













    </ScrollViewer>

</Page>
