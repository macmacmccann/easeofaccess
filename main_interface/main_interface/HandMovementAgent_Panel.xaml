<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="main_interface.HandMovementAgent_Panel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:main_interface"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid RowDefinitions="0.2*,*">

            <!-- HEADER -->
            <Border x:Name="Headertop">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Top" Height="120" Padding="16" Margin="24,24,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Hand Gesture Control" FontSize="30" FontWeight="SemiBold" />
                        <TextBlock Text="Control your computer with hand gestures — no mouse or keyboard needed" FontSize="14" Opacity="0.7" />
                    </StackPanel>

                    <ToggleSwitch
                        x:Name="GesturesEnabledToggle"
                        OffContent="Off"
                        OnContent="On"
                        Toggled="GesturesEnabledToggled"
                        FontSize="16" MinHeight="48" Padding="4" VerticalAlignment="Center">
                        <ToggleSwitch.RenderTransform>
                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                        </ToggleSwitch.RenderTransform>
                    </ToggleSwitch>
                </StackPanel>
            </Border>
            <!-- END HEADER -->

            <!-- BODY: left status + right gesture mappings -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16" Margin="24,24,0,0">

                <!-- LEFT: live feed + gesture shape guide -->
                <StackPanel Grid.Column="0" Spacing="16">

                    <TextBlock Text="What this does" FontSize="20" Opacity="0.7" />

                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                        <TextBlock
                            Text="Your webcam reads your hand shape in real time and fires a Windows action the moment a gesture is detected — assign any gesture to any action on the right, or set it to None to ignore it."
                            FontSize="13"
                            Opacity="0.85"
                            TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Live gesture feed" FontSize="20" Opacity="0.7" />

                    <!-- Live gesture readout -->
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Current gesture" FontSize="13" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock
                                x:Name="GestureLabel"
                                Text="none"
                                FontSize="48"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock
                                x:Name="StatusLabel"
                                Text="Waiting for Python to connect..."
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Opacity="0.5"/>
                        </StackPanel>
                    </Border>

                    <!-- Gesture shape guide -->
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,16,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="How to make each gesture" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="✋  open_hand   — all fingers extended"       FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="✊  fist        — all fingers closed"          FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="☝  pointing    — index finger raised"          FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="✌  peace       — index + middle raised"        FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="🤙  pinky      — pinky + thumb extended"       FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="👈  swipe_left  — hand sweeps left"            FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="👉  swipe_right — hand sweeps right"           FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- RIGHT: per-gesture action dropdowns -->
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock Text="Gesture actions" FontSize="20" Opacity="0.7" VerticalAlignment="Top" />

                    <!-- open_hand -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="✋  Open Hand" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="OpenHandCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- fist -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="✊  Fist" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="FistCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- pointing -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="☝  Pointing" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="PointingCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- peace -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="✌  Peace" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="PeaceCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- pinky -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="🤙  Pinky" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="PinkyCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- swipe_left -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="👈  Swipe Left" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="SwipeLeftCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- swipe_right -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16" Margin="0,8,24,8"
                            PointerEntered="Border_PointerEntered" PointerExited="Border_PointerExited">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="👉  Swipe Right" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="SwipeRightCombo" SelectedIndex="0"
                                      VerticalAlignment="Center" Margin="16,0,0,0" MinWidth="170">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Minimize Window"/>
                                <ComboBoxItem Content="Maximize Window"/>
                                <ComboBoxItem Content="Left Click"/>
                                <ComboBoxItem Content="Volume Up"/>
                                <ComboBoxItem Content="Volume Down"/>
                                <ComboBoxItem Content="Previous Desktop"/>
                                <ComboBoxItem Content="Next Desktop"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                </StackPanel>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>
